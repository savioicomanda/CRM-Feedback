{
  "entities": {
    "Guest": {
      "title": "Guest",
      "description": "A customer of the restaurant",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the guest" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "phone": { "type": "string", "description": "Phone number" },
        "role": { "type": "string", "enum": ["VIP", "Regular", "New"], "description": "Guest status" },
        "bio": { "type": "string", "description": "Short biography or profession" },
        "location": { "type": "string", "description": "City and country" },
        "maitreNotes": { "type": "string", "description": "Internal notes from the Maitre D'" },
        "preferences": {
          "type": "object",
          "properties": {
            "drink": { "type": "string" },
            "dish": { "type": "string" },
            "zone": { "type": "string" },
            "spending": { "type": "string" }
          }
        },
        "loyaltyStatus": { "type": "string", "description": "Current loyalty tier" },
        "visitsCount": { "type": "number" },
        "lifetimeScore": { "type": "number" },
        "lastVisit": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "Customer feedback for a visit",
      "type": "object",
      "properties": {
        "guestId": { "type": "string", "description": "ID of the guest" },
        "guestName": { "type": "string", "description": "Full name of the guest" },
        "email": { "type": "string", "format": "email", "description": "Email address for notifications" },
        "phone": { "type": "string", "description": "Phone number with mask" },
        "ratings": {
          "type": "object",
          "properties": {
            "food": { "type": "number" },
            "service": { "type": "number" },
            "ambience": { "type": "number" }
          }
        },
        "comment": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDENTE", "VISUALIZADO", "RESPONDIDO"] },
        "category": { "type": "string", "enum": ["ELOGIO", "RECLAMAÇÃO", "SUGESTÃO"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["guestId", "guestName", "email", "ratings", "timestamp"]
    },
    "Visit": {
      "title": "Visit",
      "description": "A specific dining instance",
      "type": "object",
      "properties": {
        "guestId": { "type": "string" },
        "type": { "type": "string", "description": "e.g., Dinner Service, Executive Lunch" },
        "date": { "type": "string", "format": "date-time" },
        "score": { "type": "number" },
        "comment": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["guestId", "date", "score"]
    },
    "CompanySettings": {
      "title": "Company Settings",
      "description": "Global configuration for the company identity",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "logoUrl": { "type": "string" },
        "googleReviewUrl": { "type": "string", "description": "Link to the Google Business Profile review page" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["name"]
    },
    "AppUser": {
      "title": "App User",
      "description": "A user of the management system",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the user" },
        "login": { "type": "string", "description": "Login username" },
        "email": { "type": "string", "format": "email", "description": "User email for authentication and password resets" },
        "permissions": {
          "type": "object",
          "properties": {
            "canEdit": { "type": "boolean" },
            "canDelete": { "type": "boolean" }
          }
        },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["name", "login", "permissions"]
    },
    "EmailSettings": {
      "title": "Email Settings",
      "description": "Email configuration for system notifications",
      "type": "object",
      "properties": {
        "provider": { "type": "string", "enum": ["smtp", "resend"], "description": "Email provider to use" },
        "host": { "type": "string", "description": "SMTP server host" },
        "port": { "type": "number", "description": "SMTP server port" },
        "user": { "type": "string", "description": "SMTP username" },
        "password": { "type": "string", "description": "SMTP password" },
        "resendApiKey": { "type": "string", "description": "Resend API Key (if using Resend)" },
        "fromEmail": { "type": "string", "description": "Sender email address" },
        "fromName": { "type": "string", "description": "Display name for sent emails" },
        "secure": { "type": "boolean", "description": "Use SSL/TLS" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["provider"]
    },
    "Migration": {
      "title": "Migration",
      "description": "A record of a database migration that has been executed",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "executedAt": { "type": "string", "format": "date-time" },
        "executedBy": { "type": "string" }
      },
      "required": ["id", "name", "executedAt"]
    }
  },
  "firestore": {
    "/guests/{guestId}": {
      "schema": { "$ref": "Guest" },
      "description": "Collection of restaurant guests"
    },
    "/feedbacks/{feedbackId}": {
      "schema": { "$ref": "Feedback" },
      "description": "Collection of guest feedbacks"
    },
    "/guests/{guestId}/visits/{visitId}": {
      "schema": { "$ref": "Visit" },
      "description": "Subcollection of visits for a specific guest"
    },
    "/settings/company": {
      "schema": { "$ref": "CompanySettings" },
      "description": "Global company settings document"
    },
    "/settings/email": {
      "schema": { "$ref": "EmailSettings" },
      "description": "SMTP configuration for the system"
    },
    "/users/{userId}": {
      "schema": { "$ref": "AppUser" },
      "description": "Collection of system users and their permissions"
    },
    "/migrations/{migrationId}": {
      "schema": { "$ref": "Migration" },
      "description": "Collection of executed migrations"
    }
  }
}
